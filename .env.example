# Database
DATABASE_URL=postgresql://user:password@localhost:5432/ingestion_db
DATABASE_URL=postgresql://ashish@localhost:5432/postgres

# OpenAI (for LLM metadata extraction)
OPENAI_API_KEY=your_openai_api_key_here
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.1

# File storage
UPLOAD_DIRECTORY=./uploads
MAX_FILE_SIZE_MB=100

# Classification
CLASSIFICATION_CONFIDENCE_THRESHOLD=0.8

# API settings
API_HOST=0.0.0.0
API_PORT=8002

# SQL ingestion pipeline (auto-sql-ingestion)
# SQL_PIPELINE_API_URL=http://localhost:8000
# SQL_APPROVAL_HTTP_TIMEOUT=600
# SQL_BATCH_APPROVE_TIMEOUT=900
# SQL_APPROVE_COMPLETION_POLL_INTERVAL_SEC=5
# SQL_APPROVE_COMPLETION_POLL_MAX_ATTEMPTS=240
# SQL_BATCH_JOB_SYNC_POLL_INTERVAL_SEC=10
# SQL_BATCH_JOB_SYNC_MAX_ATTEMPTS=180
